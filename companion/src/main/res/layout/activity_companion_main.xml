<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050510">

    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/remoteRenderer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/localRenderer"
        android:layout_width="96dp"
        android:layout_height="128dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="128dp"
        android:layout_marginEnd="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#CC1A1A2E"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:text="NovaRehab Companion"
            android:textColor="#E94560"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Izberi kontakt"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvConnectionState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Povezava deluje"
            android:textColor="#B8D8FF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvContactInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Kontakt"
            android:textColor="#B8D8FF"
            android:textSize="18sp"
            android:maxLines="2" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC1A1A2E"
        android:orientation="vertical"
        android:padding="16dp">

        <Button
            android:id="@+id/btnAcceptCall"
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_marginBottom="14dp"
            android:backgroundTint="#1B8F3A"
            android:text="SPREJMI KLIC"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnRejectCall"
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_marginBottom="14dp"
            android:backgroundTint="#B71C1C"
            android:text="ZAVRNI KLIC"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCallLana"
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_marginBottom="14dp"
            android:backgroundTint="#0F3460"
            android:text="POKLIČI"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSendImage"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#305b2e"
            android:text="POŠLJI SLIKO"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSelectContact"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#333355"
            android:text="NASTAVITVE KONTAKTA"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</FrameLayout>
