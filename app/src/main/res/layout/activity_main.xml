<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#1a1a2e"
    android:padding="6dp">

    <!-- GLAVNA VSEBINA -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- ZGORNJI DEL: RADIO + HITROST -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2.6"
            android:orientation="horizontal"
            android:layout_marginBottom="5dp">

            <!-- RADIO PANEL -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.6"
                android:orientation="vertical"
                android:background="#16213e"
                android:padding="6dp"
                android:layout_marginEnd="4dp">

                <!-- RADIO ikona kot START/STOP tipka -->
                <ImageButton
                    android:id="@+id/btnRadioToggle"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_radio"
                    android:backgroundTint="#1b5e20"
                    android:scaleType="fitCenter"
                    android:padding="6dp"
                    android:layout_marginBottom="4dp"
                    android:contentDescription="Radio start/stop"/>

                <!-- Postaje 2x3 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:orientation="horizontal" android:layout_marginBottom="3dp">
                    <Button android:id="@+id/btnRadio1"
                        android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                        android:text="P1" android:textSize="9sp" android:layout_marginEnd="2dp"
                        android:backgroundTint="#0f3460" android:textColor="#ffffff" android:padding="2dp"/>
                    <Button android:id="@+id/btnRadio2"
                        android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                        android:text="P2" android:textSize="9sp"
                        android:backgroundTint="#0f3460" android:textColor="#ffffff" android:padding="2dp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:orientation="horizontal" android:layout_marginBottom="3dp">
                    <Button android:id="@+id/btnRadio3"
                        android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                        android:text="P3" android:textSize="9sp" android:layout_marginEnd="2dp"
                        android:backgroundTint="#0f3460" android:textColor="#ffffff" android:padding="2dp"/>
                    <Button android:id="@+id/btnRadio4"
                        android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                        android:text="P4" android:textSize="9sp"
                        android:backgroundTint="#0f3460" android:textColor="#ffffff" android:padding="2dp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:orientation="horizontal">
                    <Button android:id="@+id/btnRadio5"
                        android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                        android:text="P5" android:textSize="9sp" android:layout_marginEnd="2dp"
                        android:backgroundTint="#0f3460" android:textColor="#ffffff" android:padding="2dp"/>
                    <Button android:id="@+id/btnRadio6"
                        android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                        android:text="P6" android:textSize="9sp"
                        android:backgroundTint="#0f3460" android:textColor="#ffffff" android:padding="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- HITROST + IME PACIENTA -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#16213e"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPatientName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#e94560"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#ffffff"
                    android:textSize="52sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="km/h"
                    android:textColor="#444466"
                    android:textSize="11sp"/>

                <TextView
                    android:id="@+id/tvClock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#aaaaaa"
                    android:textSize="16sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- KOMUNIKACIJSKE IKONE — ViewPager za swipe -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPagerComm"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3.5"
            android:layout_marginBottom="5dp"/>

        <!-- SPODNJA TIPKA: VIDEO KLIC -->
        <Button
            android:id="@+id/btnVideoCall"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.8"
            android:text="📹  VIDEO KLIC"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:backgroundTint="#1a3a6b"/>

    </LinearLayout>

    <!-- GLASNOST — dve veliki tipki -->
    <LinearLayout
        android:layout_width="64dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#0d0d1a"
        android:gravity="center"
        android:layout_marginStart="5dp"
        android:padding="4dp">

        <Button
            android:id="@+id/btnVolUp"
            android:layout_width="56dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="＋"
            android:textSize="28sp"
            android:textStyle="bold"
            android:backgroundTint="#1b5e20"
            android:textColor="#ffffff"
            android:layout_marginBottom="6dp"
            android:padding="0dp"/>

        <TextView
            android:id="@+id/tvVolLevel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="●●●"
            android:textColor="#e94560"
            android:textSize="10sp"
            android:gravity="center"
            android:layout_marginBottom="6dp"/>

        <Button
            android:id="@+id/btnVolDown"
            android:layout_width="56dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="－"
            android:textSize="28sp"
            android:textStyle="bold"
            android:backgroundTint="#b71c1c"
            android:textColor="#ffffff"
            android:padding="0dp"/>

    </LinearLayout>

</LinearLayout>
