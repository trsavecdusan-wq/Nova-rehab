<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#1a1a2e"
    android:padding="6dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2.6"
            android:layout_marginBottom="5dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnVolDown"
                android:layout_width="56dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#B71C1C"
                android:gravity="center"
                android:text="-"
                android:textColor="#ffffff"
                android:textSize="28sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.1"
                android:layout_marginEnd="6dp"
                android:background="#16213e"
                android:orientation="vertical"
                android:padding="6dp">

                <ImageButton
                    android:id="@+id/btnRadioToggle"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:contentDescription="Radio"
                    android:src="@drawable/ic_radio"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="3dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnRadio1"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="2dp"
                        android:backgroundTint="#0f3460"
                        android:padding="2dp"
                        android:text="P1"
                        android:textColor="#ffffff"
                        android:textSize="9sp" />

                    <Button
                        android:id="@+id/btnRadio2"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:backgroundTint="#0f3460"
                        android:padding="2dp"
                        android:text="P2"
                        android:textColor="#ffffff"
                        android:textSize="9sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="3dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnRadio3"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="2dp"
                        android:backgroundTint="#0f3460"
                        android:padding="2dp"
                        android:text="P3"
                        android:textColor="#ffffff"
                        android:textSize="9sp" />

                    <Button
                        android:id="@+id/btnRadio4"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:backgroundTint="#0f3460"
                        android:padding="2dp"
                        android:text="P4"
                        android:textColor="#ffffff"
                        android:textSize="9sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnRadio5"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="2dp"
                        android:backgroundTint="#0f3460"
                        android:padding="2dp"
                        android:text="P5"
                        android:textColor="#ffffff"
                        android:textSize="9sp" />

                    <Button
                        android:id="@+id/btnRadio6"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:backgroundTint="#0f3460"
                        android:padding="2dp"
                        android:text="P6"
                        android:textColor="#ffffff"
                        android:textSize="9sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/patientInfoCard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="#16213e"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/tvLanguageFlag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SI"
                    android:textColor="#ffffff"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/tvPatientName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="4dp"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="Ime"
                    android:textColor="#e94560"
                    android:textStyle="bold"
                    app:autoSizeMaxTextSize="20sp"
                    app:autoSizeMinTextSize="14sp"
                    app:autoSizeStepGranularity="1sp"
                    app:autoSizeTextType="uniform" />

                <TextView
                    android:id="@+id/tvSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="0"
                    android:textColor="#ffffff"
                    android:textStyle="bold"
                    app:autoSizeMaxTextSize="42sp"
                    app:autoSizeMinTextSize="28sp"
                    app:autoSizeStepGranularity="1sp"
                    app:autoSizeTextType="uniform" />

                <TextView
                    android:id="@+id/tvPatientDay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="sreda"
                    android:textColor="#ffffff"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvPatientDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6. maj"
                    android:textColor="#B8D8FF"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvClock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="22:45"
                    android:textColor="#ffffff"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/btnVolUp"
                android:layout_width="56dp"
                android:layout_height="match_parent"
                android:backgroundTint="#1B5E20"
                android:gravity="center"
                android:text="+"
                android:textColor="#ffffff"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPagerComm"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3.5"
            android:layout_marginBottom="5dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.9"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnVideoCall"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#1a3a6b"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="VIDEO"
                android:textColor="#ffffff"
                android:textStyle="bold"
                app:autoSizeMaxTextSize="12sp"
                app:autoSizeMinTextSize="9sp"
                app:autoSizeStepGranularity="1sp"
                app:autoSizeTextType="uniform" />

            <Button
                android:id="@+id/btnGallery"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#305b2e"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="GALERIJA"
                android:textColor="#ffffff"
                android:textStyle="bold"
                app:autoSizeMaxTextSize="12sp"
                app:autoSizeMinTextSize="8sp"
                app:autoSizeStepGranularity="1sp"
                app:autoSizeTextType="uniform" />

            <Button
                android:id="@+id/btnMirror"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#155c47"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="OGLEDALO"
                android:textColor="#ffffff"
                android:textStyle="bold"
                app:autoSizeMaxTextSize="12sp"
                app:autoSizeMinTextSize="8sp"
                app:autoSizeStepGranularity="1sp"
                app:autoSizeTextType="uniform" />

            <Button
                android:id="@+id/btnRelax"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:backgroundTint="#5a3d7a"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="SPROSTITEV"
                android:textColor="#ffffff"
                android:textStyle="bold"
                app:autoSizeMaxTextSize="11sp"
                app:autoSizeMinTextSize="7sp"
                app:autoSizeStepGranularity="1sp"
                app:autoSizeTextType="uniform" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
