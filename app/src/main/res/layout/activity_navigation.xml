<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- KARTA -->
    <WebView
        android:id="@+id/webViewMap"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- OVERLAY ZGORAJ: Hitrost + Status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#CC000000"
        android:padding="8dp"
        android:gravity="center_vertical">

        <!-- Hitrost -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#1a1a2e"
            android:padding="8dp"
            android:layout_marginEnd="12dp">

            <TextView
                android:id="@+id/tvNavSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#ffffff"
                android:textSize="36sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="km/h"
                android:textColor="#aaaaaa"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- Status -->
        <TextView
            android:id="@+id/tvNavStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🏠 Navigacija do doma"
            android:textColor="#ffffff"
            android:textSize="14sp"/>

        <!-- Gumb DOMOV -->
        <Button
            android:id="@+id/btnNavHome"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="🏠 DOM"
            android:textSize="13sp"
            android:backgroundTint="#1b5e20"
            android:textColor="#ffffff"
            android:layout_marginEnd="8dp"/>

        <!-- Gumb NAZAJ -->
        <Button
            android:id="@+id/btnNavBack"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="✖ NAZAJ"
            android:textSize="13sp"
            android:backgroundTint="#b71c1c"
            android:textColor="#ffffff"/>

    </LinearLayout>

</FrameLayout>
