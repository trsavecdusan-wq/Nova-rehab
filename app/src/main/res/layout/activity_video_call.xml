<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <LinearLayout
        android:id="@+id/contactGridScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#0D0D1A"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="VIDEO KLIC"
                android:textColor="#E94560"
                android:textSize="24sp"
                android:textStyle="bold"
                android:maxLines="1" />

            <Button
                android:id="@+id/btnVideoBack"
                android:layout_width="140dp"
                android:layout_height="48dp"
                android:text="NAZAJ"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#333355"
                android:textColor="#FFFFFF" />

        </LinearLayout>

        <GridLayout
            android:id="@+id/gridContacts"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:columnCount="2"
            android:rowCount="3"
            android:padding="8dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/confirmScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#1A1A2E"
        android:padding="24dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/imgConfirmContact"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:scaleType="fitCenter"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvConfirmName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kontakt"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="2"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvConfirmLanguage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Slovenščina"
            android:textColor="#B8D8FF"
            android:textSize="22sp"
            android:gravity="center"
            android:layout_marginBottom="42dp" />

        <Button
            android:id="@+id/btnStartCall"
            android:layout_width="match_parent"
            android:layout_height="78dp"
            android:text="KLIC"
            android:textSize="28sp"
            android:textStyle="bold"
            android:backgroundTint="#1B8F3A"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="18dp" />

        <Button
            android:id="@+id/btnCancelCall"
            android:layout_width="match_parent"
            android:layout_height="78dp"
            android:text="PREKLIČI"
            android:textSize="28sp"
            android:textStyle="bold"
            android:backgroundTint="#B71C1C"
            android:textColor="#FFFFFF" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/callScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#1A1A2E"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvCallName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kontakt"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="2"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvCallStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kličem..."
            android:textColor="#B8D8FF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#050510">

            <org.webrtc.SurfaceViewRenderer
                android:id="@+id/remoteVideoRenderer"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <org.webrtc.SurfaceViewRenderer
                android:id="@+id/localVideoRenderer"
                android:layout_width="120dp"
                android:layout_height="160dp"
                android:layout_gravity="top|end"
                android:layout_margin="12dp" />

        </FrameLayout>

        <ImageView
            android:id="@+id/imgCallContact"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnEndCall"
            android:layout_width="match_parent"
            android:layout_height="82dp"
            android:text="PREKINI KLIC"
            android:textSize="28sp"
            android:textStyle="bold"
            android:backgroundTint="#B71C1C"
            android:textColor="#FFFFFF"
            android:layout_marginTop="12dp" />

    </LinearLayout>

</FrameLayout>
