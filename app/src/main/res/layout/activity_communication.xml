<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e">

    <!-- GLAVA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#0d0d1a"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="KOMUNIKACIJA"
            android:textColor="#e94560"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <!-- Jezik toggle -->
        <Button
            android:id="@+id/btnLangToggle"
            android:layout_width="56dp"
            android:layout_height="40dp"
            android:text="SL"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="#1a6b3c"
            android:textColor="#ffffff"
            android:layout_marginEnd="6dp"/>

        <!-- Dodaj stran -->
        <Button
            android:id="@+id/btnAddPage"
            android:layout_width="56dp"
            android:layout_height="40dp"
            android:text="+ STRAN"
            android:textSize="10sp"
            android:backgroundTint="#0f3460"
            android:textColor="#ffffff"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btnCommBack"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="NAZAJ"
            android:textSize="12sp"
            android:backgroundTint="#333355"
            android:textColor="#ffffff"/>
    </LinearLayout>

    <!-- ZADNJE SPOROCILO -->
    <TextView
        android:id="@+id/tvLastMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#ffffff"
        android:textSize="15sp"
        android:background="#0f3460"
        android:padding="10dp"
        android:visibility="gone"/>

    <!-- TABS (horizontalni scroll) -->
    <HorizontalScrollView
        android:id="@+id/tabScrollView"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:scrollbars="none"
        android:background="#0d0d1a">

        <LinearLayout
            android:id="@+id/tabLayout"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:padding="4dp"/>

    </HorizontalScrollView>

    <!-- MREZA GUMBOV 2x3 -->
    <GridLayout
        android:id="@+id/gridButtons"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="2"
        android:rowCount="3"
        android:padding="6dp"/>

</LinearLayout>
